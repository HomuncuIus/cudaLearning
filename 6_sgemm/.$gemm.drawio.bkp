        <mxCell id="Ix2WDUVs5Weqmvpd658I-917" value="&lt;span style=&quot;font-size: 36px;&quot;&gt;+&lt;/span&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" vertex="1" parent="1">
